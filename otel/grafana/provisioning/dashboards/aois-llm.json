{
  "title": "AOIS — LLM Observability",
  "uid": "aois-llm",
  "schemaVersion": 38,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Requests / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_requests_total{job=\"aois-app\"}[1m]) * 60",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P99 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"aois-app\",handler=\"/analyze\"}[5m])) * 1000",
          "legendFormat": "p99 latency ms"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"aois-app\",handler=\"/analyze\"}[5m])) * 1000",
          "legendFormat": "p50 latency ms"
        }
      ]
    },
    {
      "id": 3,
      "title": "LLM Tokens In / Out",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(aois_llm_token_usage_total{token_type=\"input\"}[1m]) * 60",
          "legendFormat": "input tokens/min — {{model}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(aois_llm_token_usage_total{token_type=\"output\"}[1m]) * 60",
          "legendFormat": "output tokens/min — {{model}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cost / min (USD)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(aois_llm_cost_usd_total[1m]) * 60",
          "legendFormat": "cost/min — {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      }
    },
    {
      "id": 5,
      "title": "LLM Latency by Model (p99, ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(aois_llm_duration_ms_bucket[5m]))",
          "legendFormat": "p99 — {{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      }
    },
    {
      "id": 6,
      "title": "Severity Distribution",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(aois_incidents_total[1h])",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Recent AOIS Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"aois\"}",
          "legendFormat": ""
        }
      ]
    }
  ]
}
